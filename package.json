{
  "name": "ozendate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "format": "bunx @biomejs/biome format ./src --write",
    "build": "bun build.ts && find dist -type f -name '*.html' -exec mv {} dist/ \\;",
    "push": "cp appsscript.json dist && clasp push && rm -rf dist/*",
    "preview": "vite preview",
    "check": "biome check src",
    "preinstall": "npx only-allow bun; npx typesync || :",
    "prepare": "npx simple-git-hooks || :",
    "update": "bunx ncu -u"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.1",
    "gas-client": "^1.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "rollup": "^4.60.1",
    "stylelint-config-recommended": "^18.0.0",
    "swr": "^2.4.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/google-apps-script": "^2.0.8",
    "@types/lint-staged": "^14.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.27.4",
    "esbuild-gas-plugin": "^0.10.0",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.14",
    "npm-check-updates": "^20.0.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-singlefile": "^2.3.2"
  },
  "simple-git-hooks": {
    "pre-commit": ". ./lint-staged-each.sh"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
