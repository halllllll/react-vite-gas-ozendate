{
  "name": "ozendate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "format": "bunx @biomejs/biome format ./src --write",
    "build": "tsgo --extendedDiagnostics && bun build.ts && find dist -type f -name '*.html' -exec mv {} dist/ \\;",
    "push": "cp appsscript.json dist && clasp push && rm -rf dist/*",
    "preview": "vite preview",
    "check": "biome check src",
    "preinstall": "npx only-allow bun; npx typesync || :",
    "prepare": "npx simple-git-hooks || :",
    "update": "bunx ncu -u"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "gas-client": "^1.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "rollup": "^4.59.0",
    "stylelint-config-recommended": "^16.0.0",
    "swr": "^2.4.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/google-apps-script": "^1.0.100",
    "@types/lint-staged": "^13.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260302.1",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.25.12",
    "esbuild-gas-plugin": "^0.9.0",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.1",
    "msw": "^2.12.10",
    "npm-check-updates": "^18.3.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "5.8.3",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": ". ./lint-staged-each.sh"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}